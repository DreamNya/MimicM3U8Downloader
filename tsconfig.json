{
    "compilerOptions": {
        "target": "ES2025",
        "lib": ["ES2025"],
        "types": ["node"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": false,
        "noEmit": true
    }
}
