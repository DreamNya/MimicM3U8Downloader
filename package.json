{
    "name": "mimicm3u8downloader",
    "version": "0.0.2",
    "description": "m3u8 downloader with browser tls fingerprint",
    "type": "module",
    "scripts": {
        "server": "node src/bin/server.ts",
        "registerUrlProtocol": "node src/bin/protocol.ts --register",
        "unregisterUrlProtocol": "node src/bin/protocol.ts --unregister"
    },
    "author": "DreamNya",
    "license": "MIT",
    "imports": {
        "#/*": "./",
        "#src/*": "./src/*",
        "#setting/*": "./setting/*"
    },
    "dependencies": {
        "impit": "^0.14.2",
        "p-limit": "^7.3.0"
    },
    "devDependencies": {
        "@types/node": "^24.13.2",
        "@typescript-eslint/eslint-plugin": "^8.62.0",
        "@typescript-eslint/parser": "^8.62.0",
        "eslint": "^8.54.0",
        "typescript": "^5.9.3"
    },
    "keywords": [
        "m3u8",
        "downloader",
        "tls-fingerprint",
        "cloudflare-bypass",
        "ffmpeg",
        "impit"
    ]
}
